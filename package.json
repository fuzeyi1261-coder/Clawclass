{
  "name": "classscore",
  "productName": "班级积分系统",
  "version": "1.0.0",
  "description": "悬浮球式课堂实时加减分工具",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run electron:dev\"",
    "electron:dev": "node scripts/wait-for-vite.js && electron .",
    "build": "vite build && npm run electron:build",
    "electron:build": "node scripts/copy-electron.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:x86": "npm run build && electron-builder --win --ia32",
    "dist:win:x64": "npm run build && electron-builder --win --x64",
    "dist:mac": "npm run build && electron-builder --mac",
    "start:api": "node scripts/start-api-server.js",
    "test:api": "node scripts/test-api-server.js",
    "test:api:legacy": "node scripts/test-api.js"
  },
  "keywords": [
    "classroom",
    "score",
    "teacher",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "rollup": "^4.60.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.classscore.app",
    "productName": "班级积分系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "float.html",
      "panel.html"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "班级积分系统",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "班级积分系统-便携版-${version}.exe"
    },
    "asar": true,
    "compression": "maximum"
  }
}
