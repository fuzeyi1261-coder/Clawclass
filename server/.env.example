# 班级积分系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 服务器端口 (默认: 3000)
PORT=3000

# JWT 密钥 (生产环境必须修改！)
# 生成一个强密钥: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# 数据库路径 (可选，默认: ./data/clawclass.db)
# DB_PATH=./data/clawclass.db

# 环境模式 (development / production)
NODE_ENV=production

# 允许的来源域名 (用于 CORS，多个域名用逗号分隔)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
